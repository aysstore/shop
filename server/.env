# ============================================
# این فایل فقط برای نمونه است
# کپی کنید و نام آن را به .env تغییر دهید
# ============================================

# تنظیمات عمومی
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000/api
CLIENT_URL=http://localhost:3000

# پایگاه داده
MONGODB_URI=mongodb://localhost:27017/ays

# امنیت و توکن
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ایمیل
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# پرداخت - Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# پرداخت - زرین‌پال
ZARINPAL_MERCHANT_ID=your_merchant_id
ZARINPAL_CALLBACK_URL=http://localhost:3000/payment/verify

# Redis (اختیاری)
REDIS_URL=redis://localhost:6379
